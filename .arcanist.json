{
  "appRuntime": {
    "kind": "web",
    "runner": "docker",
    "entry": {
      "type": "compose",
      "files": ["compose.yaml"],
      "service": "linkwarden"
    },
    "url": {
      "hostPort": 3000,
      "path": "/"
    },
    "ready": {
      "path": "/",
      "timeoutSeconds": 900
    },
    "open": {
      "path": "/"
    },
    "e2e": {
      "testCommand": "curl -fsS http://127.0.0.1:3000/ >/dev/null && docker compose exec -T postgres psql -U postgres -d postgres -c \"SELECT 1;\""
    }
  }
}
